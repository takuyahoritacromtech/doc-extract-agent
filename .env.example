# Copy to `.env` and fill in. `.env` is git-ignored and never committed.

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Optional: model used for extraction. Defaults to a current vision-capable Claude model.
DOC_EXTRACT_MODEL=claude-sonnet-4-6

# Optional: reject documents larger than this (megabytes). Default 10.
DOC_EXTRACT_MAX_FILE_MB=10

# Optional: how many times to retry transient LLM failures (429/5xx/timeout). Default 3.
DOC_EXTRACT_MAX_RETRIES=3

# Optional: fields with confidence below this (0-1) are flagged for human review. Default 0.75.
DOC_EXTRACT_REVIEW_THRESHOLD=0.75

# Optional: log level (fatal|error|warn|info|debug|trace). Default info.
LOG_LEVEL=info
